{
  "title": "Application Logs",
  "uid": "sre-logs",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "tags": ["sre", "logs", "loki"],
  "description": "Structured application logs via Loki — all logs, errors, and log rate analysis",
  "panels": [
    {
      "id": 1,
      "title": "All Application Logs",
      "type": "logs",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "expr": "{job=\"sre-platform\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Errors & Warnings Only",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "expr": "{job=\"sre-platform\"} | json | level =~ \"ERROR|WARNING|CRITICAL\"",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Log Rate by Level",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "unit": "logs/s",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate({job=\"sre-platform\"} | json | level=\"INFO\" [1m]))",
          "legendFormat": "INFO",
          "refId": "A"
        },
        {
          "expr": "sum(rate({job=\"sre-platform\"} | json | level=\"WARNING\" [1m]))",
          "legendFormat": "WARNING",
          "refId": "B"
        },
        {
          "expr": "sum(rate({job=\"sre-platform\"} | json | level=\"ERROR\" [1m]))",
          "legendFormat": "ERROR",
          "refId": "C"
        }
      ]
    },
    {
      "id": 4,
      "title": "HTTP Status Code Distribution (from logs)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate({job=\"sre-platform\"} | json | status_code >= 200 < 300 [1m]))",
          "legendFormat": "2xx Success",
          "refId": "A"
        },
        {
          "expr": "sum(rate({job=\"sre-platform\"} | json | status_code >= 400 < 500 [1m]))",
          "legendFormat": "4xx Client Error",
          "refId": "B"
        },
        {
          "expr": "sum(rate({job=\"sre-platform\"} | json | status_code >= 500 [1m]))",
          "legendFormat": "5xx Server Error",
          "refId": "C"
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_LOKI",
        "type": "datasource",
        "query": "loki",
        "current": { "selected": true, "text": "Loki", "value": "Loki" },
        "hide": 2
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  }
}
