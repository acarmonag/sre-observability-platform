{
  "title": "Trace Analysis",
  "uid": "sre-traces",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "tags": ["sre", "traces", "jaeger"],
  "description": "Trace latency distributions from Prometheus histograms, with links to Jaeger UI for trace exploration",
  "links": [
    {
      "title": "Open Jaeger UI",
      "url": "http://localhost:16686",
      "targetBlank": true,
      "type": "link",
      "icon": "external link"
    }
  ],
  "panels": [
    {
      "id": 1,
      "title": "Trace Latency Heatmap",
      "type": "heatmap",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "calculate": false,
        "yAxis": { "unit": "s", "decimals": 3 },
        "color": { "mode": "scheme", "scheme": "Oranges", "fill": "dark-orange" },
        "tooltip": { "show": true, "yHistogram": false }
      },
      "targets": [
        {
          "expr": "sum(rate(http_request_duration_seconds_bucket[1m])) by (le)",
          "format": "heatmap",
          "legendFormat": "{{ le }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "p99 Latency by Endpoint",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "fillOpacity": 80, "gradientMode": "none" }
        }
      },
      "options": {
        "orientation": "horizontal",
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, endpoint))",
          "legendFormat": "{{ endpoint }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Slowest Endpoints — p95 Latency",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Endpoint" },
            "properties": [{ "id": "custom.width", "value": 250 }]
          },
          {
            "matcher": { "id": "byName", "options": "p50" },
            "properties": [{ "id": "unit", "value": "s" }, { "id": "custom.displayMode", "value": "color-background" }]
          },
          {
            "matcher": { "id": "byName", "options": "p99" },
            "properties": [
              { "id": "unit", "value": "s" },
              { "id": "custom.displayMode", "value": "color-background" },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "red", "value": 2 }] } }
            ]
          }
        ]
      },
      "options": {
        "sortBy": [{ "displayName": "p99", "desc": true }]
      },
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "endpoint": "Endpoint",
              "Value #A": "p50",
              "Value #B": "p95",
              "Value #C": "p99"
            }
          }
        }
      ],
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, endpoint))",
          "legendFormat": "p50",
          "refId": "A",
          "instant": true
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, endpoint))",
          "legendFormat": "p95",
          "refId": "B",
          "instant": true
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, endpoint))",
          "legendFormat": "p99",
          "refId": "C",
          "instant": true
        }
      ]
    },
    {
      "id": 4,
      "title": "Request Duration Distribution (last 5m)",
      "type": "histogram",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "bucketSize": "auto",
        "fillOpacity": 80,
        "gradientMode": "none",
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "sum(increase(http_request_duration_seconds_bucket[5m])) by (le, endpoint)",
          "format": "heatmap",
          "legendFormat": "{{ le }}",
          "refId": "A"
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "selected": true, "text": "Prometheus", "value": "Prometheus" },
        "hide": 2
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  }
}
